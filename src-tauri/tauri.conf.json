{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ScriptureGlide",
  "version": "0.2.9",
  "identifier": "com.scriptureglide.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScriptureGlide",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/gregvruggink/ScriptureGlide/releases/latest/download/latest.json"
      ],
      "pubkey": "RWT0509NbtQSAwpIfvjsC7YWAbU0VN0JnTfGr5gKSe5giuyaqAHsIAdS"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
